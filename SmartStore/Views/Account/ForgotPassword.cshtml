@model SmartStore.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<section class="auth-section">
    <div class="container auth-shell">
        <div class="auth-panel">
            <div class="auth-copy">
                <span class="eyebrow"><i class="fa-solid fa-key"></i> Khôi phục tài khoản</span>
                <h1>Nhận liên kết đặt lại mật khẩu qua Gmail</h1>
                <p>Nhập Gmail đã đăng ký. Hệ thống sẽ gửi email có nút đặt lại mật khẩu để bạn tạo mật khẩu mới.</p>
                <div class="auth-benefits">
                    <span><i class="fa-solid fa-circle-check"></i> Chỉ nhận địa chỉ Gmail</span>
                    <span><i class="fa-solid fa-circle-check"></i> Liên kết reset có token bảo mật</span>
                    <span><i class="fa-solid fa-circle-check"></i> Mật khẩu mới tối thiểu 6 ký tự</span>
                </div>
            </div>

            <form asp-action="ForgotPassword" method="post" class="auth-card" novalidate>
                @Html.AntiForgeryToken()

                <div class="auth-card-heading">
                    <span class="auth-icon"><i class="fa-solid fa-envelope-open-text"></i></span>
                    <div>
                        <h2>Quên mật khẩu</h2>
                        <p>Chúng tôi sẽ gửi link đặt lại mật khẩu cho bạn.</p>
                    </div>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger auth-validation"></div>

                <div class="form-group-custom">
                    <label asp-for="Email">Gmail</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-envelope"></i>
                        <input asp-for="Email" class="form-control" placeholder="ten@gmail.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary-custom auth-submit">
                    <i class="fa-solid fa-paper-plane me-1"></i> Gửi email đặt lại
                </button>

                <p class="auth-switch">
                    Nhớ mật khẩu rồi?
                    <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
                </p>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
