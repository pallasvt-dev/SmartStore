@model SmartStore.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-section">
    <div class="container auth-shell">
        <div class="auth-panel">
            <div class="auth-copy">
                <span class="eyebrow"><i class="fa-solid fa-user-plus"></i> Thành viên mới</span>
                <h1>Tạo tài khoản mua sắm trong vài giây</h1>
                <p>Đăng ký bằng Gmail, đặt mật khẩu tối thiểu 6 ký tự và bắt đầu trải nghiệm cửa hàng thời trang SmartStore.</p>
                <div class="auth-benefits">
                    <span><i class="fa-solid fa-circle-check"></i> Chỉ nhận địa chỉ Gmail</span>
                    <span><i class="fa-solid fa-circle-check"></i> Kiểm tra nhập lại mật khẩu</span>
                    <span><i class="fa-solid fa-circle-check"></i> Đăng nhập ngay sau khi đăng ký</span>
                </div>
            </div>

            <form asp-action="Register" method="post" class="auth-card" novalidate>
                @Html.AntiForgeryToken()
                <div class="auth-card-heading">
                    <span class="auth-icon"><i class="fa-solid fa-id-card"></i></span>
                    <div>
                        <h2>Đăng ký</h2>
                        <p>Điền thông tin tài khoản của bạn.</p>
                    </div>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger auth-validation"></div>

                <div class="form-group-custom">
                    <label asp-for="FullName">Họ và tên</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-user"></i>
                        <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" autocomplete="name" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Email">Gmail</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-envelope"></i>
                        <input asp-for="Email" class="form-control" placeholder="ten@gmail.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-grid-two auth-form-grid">
                    <div class="form-group-custom">
                        <label asp-for="Password">Mật khẩu</label>
                        <div class="auth-input">
                            <i class="fa-solid fa-lock"></i>
                            <input asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group-custom">
                        <label asp-for="ConfirmPassword">Nhập lại mật khẩu</label>
                        <div class="auth-input">
                            <i class="fa-solid fa-key"></i>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary-custom auth-submit">
                    <i class="fa-solid fa-user-check me-1"></i> Tạo tài khoản mới
                </button>

                <p class="auth-switch">
                    Đã có tài khoản?
                    <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
                </p>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
