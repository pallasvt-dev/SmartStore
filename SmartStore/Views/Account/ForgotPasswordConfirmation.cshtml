@{
    ViewData["Title"] = "Đã gửi email";
}

<section class="auth-section">
    <div class="container auth-shell">
        <div class="auth-card access-denied-card">
            <div class="auth-card-heading">
                <span class="auth-icon"><i class="fa-solid fa-envelope-circle-check"></i></span>
                <div>
                    <h2>Kiểm tra Gmail của bạn</h2>
                    <p>Nếu Gmail tồn tại trong hệ thống, email đặt lại mật khẩu đã được gửi.</p>
                </div>
            </div>
            <div class="auth-benefits">
                <span><i class="fa-solid fa-circle-info"></i> Mở email và nhấn nút đặt lại mật khẩu.</span>
                <span><i class="fa-solid fa-circle-check"></i> Sau đó bạn sẽ được chuyển tới giao diện tạo mật khẩu mới.</span>
            </div>
            <div class="form-actions mt-4">
                <a class="btn btn-primary-custom" asp-controller="Account" asp-action="Login">Về đăng nhập</a>
                <a class="btn btn-outline-custom" asp-controller="Home" asp-action="Index">Về trang chủ</a>
            </div>
        </div>
    </div>
</section>
