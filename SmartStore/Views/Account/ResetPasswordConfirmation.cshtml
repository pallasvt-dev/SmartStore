@{
    ViewData["Title"] = "Đã đặt lại mật khẩu";
}

<section class="auth-section">
    <div class="container auth-shell">
        <div class="auth-card access-denied-card">
            <div class="auth-card-heading">
                <span class="auth-icon"><i class="fa-solid fa-circle-check"></i></span>
                <div>
                    <h2>Mật khẩu đã được cập nhật</h2>
                    <p>Bạn có thể đăng nhập bằng mật khẩu mới ngay bây giờ.</p>
                </div>
            </div>
            <div class="form-actions mt-4">
                <a class="btn btn-primary-custom" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                <a class="btn btn-outline-custom" asp-controller="Home" asp-action="Index">Về trang chủ</a>
            </div>
        </div>
    </div>
</section>
