@model SmartStore.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<section class="auth-section">
    <div class="container auth-shell">
        <div class="auth-panel">
            <div class="auth-copy">
                <span class="eyebrow"><i class="fa-solid fa-key"></i> Mật khẩu mới</span>
                <h1>Tạo mật khẩu mới cho tài khoản</h1>
                <p>Nhập mật khẩu mới tối thiểu 6 ký tự. Sau khi lưu, bạn có thể đăng nhập bằng mật khẩu mới.</p>
                <div class="auth-benefits">
                    <span><i class="fa-solid fa-circle-check"></i> Token reset bảo mật từ email</span>
                    <span><i class="fa-solid fa-circle-check"></i> Kiểm tra nhập lại mật khẩu</span>
                    <span><i class="fa-solid fa-circle-check"></i> Đăng nhập lại sau khi đổi mật khẩu</span>
                </div>
            </div>

            <form asp-action="ResetPassword" method="post" class="auth-card" novalidate>
                @Html.AntiForgeryToken()
                <input asp-for="Email" type="hidden" />
                <input asp-for="Token" type="hidden" />

                <div class="auth-card-heading">
                    <span class="auth-icon"><i class="fa-solid fa-lock"></i></span>
                    <div>
                        <h2>Đặt lại mật khẩu</h2>
                        <p>Tài khoản: @Model.Email</p>
                    </div>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger auth-validation"></div>

                <div class="form-group-custom">
                    <label asp-for="Password">Mật khẩu mới</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-lock"></i>
                        <input asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="ConfirmPassword">Nhập lại mật khẩu mới</label>
                    <div class="auth-input">
                        <i class="fa-solid fa-key"></i>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary-custom auth-submit">
                    <i class="fa-solid fa-check me-1"></i> Lưu mật khẩu mới
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
