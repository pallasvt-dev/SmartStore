@{
    ViewData["Title"] = "Không có quyền";
}

<section class="auth-section">
    <div class="container auth-shell">
        <div class="auth-card access-denied-card">
            <div class="auth-card-heading">
                <span class="auth-icon"><i class="fa-solid fa-lock"></i></span>
                <div>
                    <h2>Không có quyền truy cập</h2>
                    <p>Tài khoản của bạn chưa có role phù hợp để mở trang này.</p>
                </div>
            </div>
            <div class="auth-benefits">
                <span><i class="fa-solid fa-circle-info"></i> Trang quản lý sản phẩm chỉ dành cho Admin.</span>
                <span><i class="fa-solid fa-circle-check"></i> Tài khoản đăng ký mới mặc định là Customer.</span>
            </div>
            <div class="form-actions mt-4">
                <a class="btn btn-primary-custom" asp-controller="Home" asp-action="Index">Về trang chủ</a>
                <a class="btn btn-outline-custom" asp-controller="Account" asp-action="Login">Đăng nhập tài khoản khác</a>
            </div>
        </div>
    </div>
</section>
