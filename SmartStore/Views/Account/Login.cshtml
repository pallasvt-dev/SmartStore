@model SmartStore.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    var returnUrl = Model.ReturnUrl ?? $"{Context.Request.Path}{Context.Request.QueryString}";
}

<section class="auth-section">
    <div class="container auth-shell">
        <div class="auth-panel">
            <div class="auth-copy">
                <span class="eyebrow"><i class="fa-solid fa-shield-halved"></i> Tài khoản mua sắm</span>
                <h1>Đăng nhập để tiếp tục mua hàng</h1>
                <p>Quản lý giỏ hàng, theo dõi sản phẩm yêu thích và thao tác nhanh hơn với tài khoản của bạn.</p>
                <div class="auth-benefits">
                    <span><i class="fa-solid fa-circle-check"></i> Đăng nhập bằng Gmail và mật khẩu</span>
                    <span><i class="fa-solid fa-circle-check"></i> Đăng nhập nhanh bằng Google</span>
                    <span><i class="fa-solid fa-circle-check"></i> Có thể đặt lại mật khẩu qua Gmail</span>
                </div>
            </div>

            <div class="auth-card">
                <div class="auth-card-heading">
                    <span class="auth-icon"><i class="fa-solid fa-user"></i></span>
                    <div>
                        <h2>Đăng nhập</h2>
                        <p>Nhập Gmail và mật khẩu, hoặc dùng Google.</p>
                    </div>
                </div>

                <form asp-action="Login" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input asp-for="ReturnUrl" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger auth-validation"></div>

                    <div class="form-group-custom">
                        <label asp-for="Email">Gmail</label>
                        <div class="auth-input">
                            <i class="fa-solid fa-envelope"></i>
                            <input asp-for="Email" class="form-control" placeholder="ten@gmail.com" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group-custom">
                        <div class="auth-label-row">
                            <label asp-for="Password">Mật khẩu</label>
                            <a asp-controller="Account" asp-action="ForgotPassword">Quên mật khẩu?</a>
                        </div>
                        <div class="auth-input">
                            <i class="fa-solid fa-lock"></i>
                            <input asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" autocomplete="current-password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary-custom auth-submit">
                        <i class="fa-solid fa-right-to-bracket me-1"></i> Đăng nhập
                    </button>
                </form>

                <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="external-login-form google-login-below">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="provider" value="Google" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button type="submit" class="google-login-btn">
                        <i class="fa-brands fa-google"></i>
                        <span>Đăng nhập bằng Google</span>
                    </button>
                </form>

                <p class="auth-switch">
                    Chưa có tài khoản?
                    <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
