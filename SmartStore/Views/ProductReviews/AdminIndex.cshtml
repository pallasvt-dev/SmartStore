@model List<ProductReview>
@{
    ViewData["Title"] = "Quản lý đánh giá";
}

<section class="review-admin-page">
    <header class="admin-page-header">
        <div>
            <span class="eyebrow dark"><i class="fa-solid fa-star"></i> Tương tác khách hàng</span>
            <h1>Quản lý đánh giá</h1>
            <p>Duyệt, ẩn hoặc xóa nhận xét sản phẩm của khách hàng.</p>
        </div>
        <span class="admin-count-badge">@Model.Count đánh giá</span>
    </header>

    @if (TempData["ReviewAdminMessage"] != null)
    {
        <div class="alert cart-alert" role="alert"><i class="fa-solid fa-circle-check"></i><span>@TempData["ReviewAdminMessage"]</span><button type="button" class="alert-close" aria-label="Đóng thông báo"><i class="fa-solid fa-xmark"></i></button></div>
    }

    <div class="admin-table-card">
        @if (Model.Count == 0)
        {
            <div class="admin-empty-state"><i class="fa-regular fa-comment-dots"></i><h2>Chưa có đánh giá nào.</h2><p>Đánh giá của khách hàng sẽ xuất hiện tại đây.</p></div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table admin-table admin-review-table align-middle">
                    <thead><tr><th>Sản phẩm</th><th>Khách hàng</th><th>Đánh giá</th><th>Nội dung</th><th>Ngày gửi</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
                    <tbody>
                        @foreach (var review in Model)
                        {
                            <tr>
                                <td><strong>@review.Product.Name</strong></td>
                                <td>@review.User.FullName</td>
                                <td><span class="admin-rating" aria-label="@review.Rating sao"><i class="fa-solid fa-star"></i> @review.Rating/5</span></td>
                                <td><p class="admin-review-comment">@review.Comment</p>@if (review.Images.Count > 0) { <small class="table-subtext"><i class="fa-regular fa-image"></i> @review.Images.Count ảnh đính kèm</small> }</td>
                                <td>@review.CreatedAt.ToString("dd/MM/yyyy")<small class="table-subtext">@review.CreatedAt.ToString("HH:mm")</small></td>
                                <td><span class="admin-badge @(review.IsApproved ? "status-visible" : "status-hidden")">@(review.IsApproved ? "Đang hiển thị" : "Đã ẩn")</span></td>
                                <td>
                                    <div class="admin-actions justify-content-end">
                                        @if (review.IsApproved)
                                        {
                                            <form asp-action="Hide" asp-route-id="@review.Id" method="post">@Html.AntiForgeryToken()<button class="action-btn edit" type="submit" title="Ẩn đánh giá"><i class="fa-solid fa-eye-slash"></i></button></form>
                                        }
                                        else
                                        {
                                            <form asp-action="Approve" asp-route-id="@review.Id" method="post">@Html.AntiForgeryToken()<button class="action-btn view" type="submit" title="Hiển thị đánh giá"><i class="fa-solid fa-eye"></i></button></form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@review.Id" method="post" class="js-admin-confirm" data-confirm="Bạn chắc chắn muốn xóa đánh giá này?">@Html.AntiForgeryToken()<button class="action-btn delete" type="submit" title="Xóa đánh giá"><i class="fa-solid fa-trash-can"></i></button></form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
