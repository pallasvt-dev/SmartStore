@using SmartStore.Models
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager
@{
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
    var signedInUser = isLoggedIn ? await UserManager.GetUserAsync(User) : null;
    var currentUserName = signedInUser?.FullName ?? User.Identity?.Name;
    var isAdmin = User.IsInRole(AppRoles.Admin);
    var isCustomer = User.IsInRole(AppRoles.Customer);
    var currentRole = isAdmin ? "Quản trị viên" : isCustomer ? "Khách hàng" : string.Empty;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartStore.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg main-navbar">
            <div class="container">
                <a class="navbar-brand brand-logo" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon"><i class="fa-solid fa-bag-shopping"></i></span>
                    <span>SmartStore</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu" aria-controls="mainMenu" aria-expanded="false" aria-label="Mở menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainMenu">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/#san-pham">Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">Liên hệ</a>
                        </li>

                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-admin" asp-controller="Admin" asp-action="Index">
                                    <i class="fa-solid fa-gauge-high me-1"></i> Bảng điều khiển
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-admin" asp-controller="Products" asp-action="Index">
                                    <i class="fa-solid fa-boxes-stacked me-1"></i> Quản lý sản phẩm
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-admin" asp-controller="Orders" asp-action="AdminIndex">
                                    <i class="fa-solid fa-clipboard-list me-1"></i> Quản lý đơn hàng
                                </a>
                            </li>
                        }

                        @if (isCustomer)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Orders" asp-action="MyOrders">
                                    <i class="fa-solid fa-receipt me-1"></i> Đơn hàng của tôi
                                </a>
                            </li>
                        }

                        @if (isLoggedIn)
                        {
                            <li class="nav-item ms-lg-2">
                                @await Component.InvokeAsync("CartSummary")
                            </li>
                            <li class="nav-item">
                                <span class="nav-user" title="Xin chào, @currentUserName">
                                    <i class="fa-solid fa-circle-user"></i>
                                    <span>Xin chào, @currentUserName@if (!string.IsNullOrWhiteSpace(currentRole)) { <small>@currentRole</small> }</span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="nav-auth-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-nav btn-nav-light">
                                        <i class="fa-solid fa-right-from-bracket"></i>
                                        <span>Đăng xuất</span>
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-2">
                                <a class="btn-nav btn-nav-light" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl">
                                    <i class="fa-solid fa-right-to-bracket"></i>
                                    <span>Đăng nhập</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn-nav" asp-controller="Account" asp-action="Register">
                                    <i class="fa-solid fa-user-plus"></i>
                                    <span>Đăng ký</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (TempData["AuthMessage"] != null)
    {
        <div class="container auth-toast-wrap">
            <div class="alert alert-success cart-alert" role="alert">
                <i class="fa-solid fa-circle-check"></i>
                <span>@TempData["AuthMessage"]</span>
                <button type="button" class="alert-close" aria-label="Đóng thông báo">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </div>
    }

    <main id="page-content" role="main" tabindex="-1">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-grid">
            <div class="footer-col">
                <h3>SmartStore</h3>
                <p>Cửa hàng thời trang hiện đại với sản phẩm có kích cỡ, màu sắc và tồn kho rõ ràng theo từng biến thể.</p>
            </div>
            <div class="footer-col">
                <h3>Liên kết</h3>
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a href="/#san-pham">Sản phẩm</a>
                @if (isLoggedIn)
                {
                    <a asp-controller="Cart" asp-action="Index">Giỏ hàng</a>
                }
                @if (isCustomer)
                {
                    <a asp-controller="Orders" asp-action="MyOrders">Đơn hàng của tôi</a>
                }
                @if (isAdmin)
                {
                    <a asp-controller="Admin" asp-action="Index">Bảng điều khiển</a>
                    <a asp-controller="Products" asp-action="Index">Quản lý sản phẩm</a>
                    <a asp-controller="Orders" asp-action="AdminIndex">Quản lý đơn hàng</a>
                }
                <a asp-controller="Home" asp-action="Contact">Liên hệ</a>
            </div>
            <div class="footer-col">
                <h3>Theo dõi</h3>
                <div class="footer-socials">
                    <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" aria-label="X"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">© 2026 SmartStore. Thiết kế tối ưu cho trải nghiệm mua sắm thời trang.</div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
