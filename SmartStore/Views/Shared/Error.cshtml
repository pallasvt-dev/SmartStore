@model ErrorViewModel
@{
    ViewData["Title"] = "Đã xảy ra lỗi";
}

<section class="contact-section">
    <div class="container contact-card">
        <span class="eyebrow danger"><i class="fa-solid fa-triangle-exclamation"></i> Lỗi hệ thống</span>
        <h1>Đã xảy ra lỗi khi xử lý yêu cầu</h1>

        @if (Model.ShowRequestId)
        {
            <p>
                <strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <p>Vui lòng thử lại sau hoặc liên hệ cửa hàng nếu lỗi vẫn tiếp diễn.</p>
        <a class="btn btn-primary-custom" asp-controller="Home" asp-action="Index">Về trang chủ</a>
    </div>
</section>
