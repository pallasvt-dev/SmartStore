@using SmartStore.Models
@model IEnumerable<SmartStore.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
    var products = Model.ToList();
    var featured = products.FirstOrDefault();
    var featuredImage = featured?.ProductImages.OrderByDescending(i => i.IsMain).ThenBy(i => i.DisplayOrder).FirstOrDefault()?.ImageUrl;
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole(AppRoles.Admin);
    var isCustomer = User.IsInRole(AppRoles.Customer);
    var favoriteProductIds = ViewBag.FavoriteProductIds as HashSet<int> ?? new HashSet<int>();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}#san-pham";
}

<section class="hero-section">
    <div class="container hero-grid">
        <div class="hero-content">
            <span class="eyebrow"><i class="fa-solid fa-star"></i> Hàng mới về</span>
            <h1>Khám phá phong cách mới cùng SmartStore</h1>
            <p>Sản phẩm thời trang có kích cỡ, màu sắc, SKU và tồn kho rõ ràng theo từng biến thể.</p>
            <div class="hero-actions">
                <a class="btn btn-primary-custom" href="#san-pham">Xem sản phẩm</a>
                @if (isLoggedIn)
                {
                    <a class="btn btn-outline-custom" asp-controller="Cart" asp-action="Index"><i class="fa-solid fa-cart-shopping me-1"></i> Xem giỏ hàng</a>
                }
                else
                {
                    <a class="btn btn-outline-custom" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl"><i class="fa-solid fa-right-to-bracket me-1"></i> Đăng nhập để mua hàng</a>
                }
                @if (isAdmin)
                {
                    <a class="btn btn-outline-custom" asp-controller="Products" asp-action="Index"><i class="fa-solid fa-boxes-stacked me-1"></i> Quản lý sản phẩm</a>
                }
            </div>
            <div class="hero-stats">
                <div><strong>@products.Count</strong><span>Sản phẩm</span></div>
                <div><strong>@products.Sum(p => p.ProductVariants.Count(v => v.IsActive))</strong><span>Biến thể</span></div>
                <div><strong>@products.Sum(p => p.ProductVariants.Where(v => v.IsActive).Sum(v => v.StockQuantity))</strong><span>Tồn kho</span></div>
            </div>
        </div>
        <div class="hero-card">
            @if (featured != null)
            {
                <span class="floating-badge">@(featured.Badge ?? "Mới")</span>
                <img src="@featuredImage" alt="@featured.Name" />
                <div class="hero-card-info">
                    <span>Sản phẩm nổi bật</span>
                    <h2>@featured.Name</h2>
                    <p>@UiFormat.Vnd(featured.Price)</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="container shop-section" id="san-pham">
    @if (TempData["CartMessage"] != null)
    {
        <div class="alert alert-success cart-alert" role="alert">
            <i class="fa-solid fa-circle-check"></i>
            <span>@TempData["CartMessage"]</span>
            <a asp-controller="Cart" asp-action="Index">Xem giỏ hàng</a>
            <button type="button" class="alert-close" aria-label="Đóng thông báo">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    }

    <div class="section-heading">
        <div>
            <span class="eyebrow dark"><i class="fa-solid fa-layer-group"></i> Sản phẩm nổi bật</span>
            <h2>@products.Count sản phẩm thời trang</h2>
        </div>
    </div>

    @if (!products.Any())
    {
        <div class="empty-cart-card">
            <div class="empty-cart-icon"><i class="fa-solid fa-shirt"></i></div>
            <h2>Chưa có sản phẩm nào</h2>
            <p>Vui lòng quay lại sau hoặc liên hệ cửa hàng để được hỗ trợ.</p>
        </div>
    }
    else
    {
        <div class="shop-grid">
            <div class="product-list">
                @foreach (var product in products)
                {
                    var mainImage = product.ProductImages.OrderByDescending(i => i.IsMain).ThenBy(i => i.DisplayOrder).FirstOrDefault()?.ImageUrl;
                    var activeVariants = product.ProductVariants.Where(v => v.IsActive).ToList();
                    var totalStock = activeVariants.Sum(v => v.StockQuantity);
                    var firstVariant = activeVariants.FirstOrDefault(v => v.StockQuantity > 0) ?? activeVariants.FirstOrDefault();
                    var isFavorite = favoriteProductIds.Contains(product.Id);
                    <article class="product-card">
                        <a class="product-image" asp-controller="Home" asp-action="Details" asp-route-id="@product.Id" aria-label="Xem @product.Name">
                            <span class="product-badge">@(totalStock > 0 ? (product.Badge ?? "Còn hàng") : "Hết hàng")</span>
                            <img src="@mainImage" alt="@product.Name" />
                        </a>
                        @if (isCustomer)
                        {
                            <form asp-controller="Wishlist" asp-action="Toggle" method="post" class="wishlist-toggle-form js-wishlist-toggle-form" data-product-id="@product.Id">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button class="wishlist-heart-btn @(isFavorite ? "active" : "")" type="submit" aria-label="@(isFavorite ? "Bỏ yêu thích" : "Thêm vào yêu thích")" title="@(isFavorite ? "Bỏ yêu thích" : "Thêm vào yêu thích")">
                                    <i class="fa-@(isFavorite ? "solid" : "regular") fa-heart"></i>
                                </button>
                            </form>
                        }
                        else if (!isLoggedIn)
                        {
                            <a class="wishlist-heart-btn" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl" aria-label="Đăng nhập để yêu thích" title="Đăng nhập để yêu thích"><i class="fa-regular fa-heart"></i></a>
                        }
                        <div class="product-body">
                            <div class="product-meta">
                                <span>@product.Category.Name</span>
                                <span class="rating"><i class="fa-solid fa-star"></i> @product.Rating</span>
                            </div>
                            <h3>@product.Name</h3>
                            <p>@product.Description</p>
                            <div class="price-row">
                                <strong>@UiFormat.Vnd(product.Price)</strong>
                                @if (product.OldPrice.HasValue)
                                {
                                    <del>@UiFormat.Vnd(product.OldPrice.Value)</del>
                                }
                            </div>
                            <div class="product-description">
                                <span>@(totalStock > 0 ? $"Còn hàng: {totalStock}" : "Hết hàng")</span>
                                <span>@activeVariants.Count biến thể</span>
                            </div>
                            <div class="card-actions">
                                <a class="btn-buy" asp-controller="Home" asp-action="Details" asp-route-id="@product.Id">Xem chi tiết</a>
                                @if (isLoggedIn && firstVariant != null && totalStock > 0)
                                {
                                    <form asp-controller="Cart" asp-action="Add" method="post" class="add-cart-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productVariantId" value="@firstVariant.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button class="btn-icon" type="submit" aria-label="Thêm @product.Name vào giỏ hàng">
                                            <i class="fa-solid fa-cart-plus"></i>
                                        </button>
                                    </form>
                                }
                                else if (!isLoggedIn)
                                {
                                    <a class="btn-icon login-cart-link" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl" aria-label="Đăng nhập để thêm @product.Name vào giỏ hàng">
                                        <i class="fa-solid fa-lock"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>

            <aside class="sidebar">
                <div class="sidebar-card social-card">
                    <h3>Theo dõi SmartStore</h3>
                    <p>Nhận thông tin hàng mới, ưu đãi và gợi ý phối đồ theo mùa.</p>
                    <a href="#"><i class="fa-brands fa-facebook-f"></i> Facebook</a>
                    <a href="#"><i class="fa-brands fa-x-twitter"></i> X</a>
                    <a href="#"><i class="fa-brands fa-instagram"></i> Instagram</a>
                    <a href="#"><i class="fa-brands fa-linkedin-in"></i> LinkedIn</a>
                </div>

                <div class="sidebar-card benefit-card">
                    <h3>Ưu điểm mua hàng</h3>
                    <ul>
                        <li><i class="fa-solid fa-circle-check"></i> Sản phẩm có kích cỡ và màu sắc rõ ràng</li>
                        <li><i class="fa-solid fa-circle-check"></i> SKU riêng cho từng biến thể</li>
                        <li><i class="fa-solid fa-circle-check"></i> Tồn kho tính theo từng kích cỡ và màu sắc</li>
                        <li><i class="fa-solid fa-circle-check"></i> Giỏ hàng lưu đúng biến thể bạn chọn</li>
                    </ul>
                </div>
            </aside>
        </div>
    }
</section>
