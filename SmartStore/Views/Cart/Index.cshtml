@model CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<section class="cart-page">
    <div class="container">
        <nav class="breadcrumb-line" aria-label="Điều hướng">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a>
            <span>/</span>
            <strong>Giỏ hàng</strong>
        </nav>

        <div class="cart-header">
            <div>
                <span class="eyebrow dark"><i class="fa-solid fa-cart-shopping"></i> Giỏ hàng</span>
                <h1>Giỏ hàng của bạn</h1>
            </div>
            <a class="btn btn-outline-custom" asp-controller="Home" asp-action="Index" asp-fragment="san-pham">
                <i class="fa-solid fa-arrow-left me-1"></i> Tiếp tục mua sắm
            </a>
        </div>

        @if (TempData["CartMessage"] != null)
        {
            <div class="alert alert-success cart-alert" role="alert">
                <i class="fa-solid fa-circle-check"></i>
                <span>@TempData["CartMessage"]</span>
                <button type="button" class="alert-close" aria-label="Đóng thông báo">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }

        @if (Model.IsEmpty)
        {
            <div class="empty-cart-card">
                <div class="empty-cart-icon"><i class="fa-solid fa-basket-shopping"></i></div>
                <h2>Giỏ hàng của bạn đang trống</h2>
                <p>Hãy khám phá các sản phẩm thời trang mới nhất tại SmartStore.</p>
                <a class="btn btn-primary-custom" asp-controller="Home" asp-action="Index" asp-fragment="san-pham">Mua sắm ngay</a>
            </div>
        }
        else
        {
            <div class="cart-layout js-cart-page">
                <div class="cart-list-card">
                    <div class="cart-list-heading" aria-hidden="true">
                        <span>Sản phẩm</span>
                        <span>Số lượng</span>
                        <span>Thành tiền</span>
                    </div>
                    @foreach (var item in Model.Items)
                    {
                        <article class="cart-item js-cart-item" data-cart-item-id="@item.CartItemId">
                            <a class="cart-item-image" asp-controller="Home" asp-action="Details" asp-route-id="@item.ProductId">
                                <img src="@item.ImageUrl" alt="@item.ProductName" />
                            </a>

                            <div class="cart-item-info">
                                <a class="cart-item-name" asp-controller="Home" asp-action="Details" asp-route-id="@item.ProductId">@item.ProductName</a>
                                <span class="cart-item-price">Kích cỡ @item.SizeName / @item.ColorName</span>
                                <span class="cart-item-price">SKU: @item.Sku</span>
                                <span class="cart-item-price">Đơn giá: @UiFormat.Vnd(item.UnitPrice)</span>
                                <span class="cart-item-price">Còn @item.StockQuantity sản phẩm</span>
                            </div>

                            <div class="cart-quantity-group">
                                <form asp-controller="Cart" asp-action="Decrease" method="post" class="js-cart-action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <button class="qty-btn" type="submit" aria-label="Giảm số lượng">
                                        <i class="fa-solid fa-minus"></i>
                                    </button>
                                </form>

                                <form asp-controller="Cart" asp-action="Update" method="post" class="quantity-update-form js-cart-action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <input class="cart-qty-input js-cart-qty-input" type="number" name="quantity" value="@item.Quantity" min="0" max="@Math.Min(item.StockQuantity, 20)" aria-label="Số lượng @item.ProductName" />
                                </form>

                                <form asp-controller="Cart" asp-action="Increase" method="post" class="js-cart-action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <button class="qty-btn" type="submit" aria-label="Tăng số lượng">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </form>
                            </div>

                            <div class="cart-line-total">
                                <span>Thành tiền</span>
                                <strong class="js-line-total">@UiFormat.Vnd(item.LineTotal)</strong>
                            </div>

                            <form asp-controller="Cart" asp-action="Remove" method="post" class="remove-form js-cart-action-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                <button class="remove-btn" type="submit" aria-label="Xóa @item.ProductName">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>
                        </article>
                    }
                </div>

                <aside class="cart-summary-card">
                    <h2>Tóm tắt đơn hàng</h2>
                    <div class="summary-row">
                        <span>Tạm tính</span>
                        <strong class="js-summary-subtotal">@UiFormat.Vnd(Model.SubTotal)</strong>
                    </div>
                    <div class="summary-row">
                        <span>Phí vận chuyển</span>
                        <strong class="js-summary-shipping">@UiFormat.Vnd(Model.ShippingFee)</strong>
                    </div>
                    <div class="summary-row discount-row">
                        <span>Giảm giá</span>
                        <strong class="js-summary-discount">-@UiFormat.Vnd(Model.Discount)</strong>
                    </div>
                    <div class="summary-total">
                        <span>Tổng cộng</span>
                        <strong class="js-summary-total">@UiFormat.Vnd(Model.Total)</strong>
                    </div>

                    <button class="btn btn-primary-custom w-100" type="button">
                        <i class="fa-solid fa-credit-card me-1"></i> Thanh toán
                    </button>

                    <form asp-controller="Cart" asp-action="Clear" method="post" class="clear-cart-form">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-danger w-100" type="submit">
                            <i class="fa-solid fa-trash-can me-1"></i> Xóa toàn bộ giỏ hàng
                        </button>
                    </form>

                    <div class="cart-note">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>Đơn từ 500.000 ₫ được giảm 50.000 ₫.</span>
                    </div>
                </aside>
            </div>
        }
    </div>
</section>
