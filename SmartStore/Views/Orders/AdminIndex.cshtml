@model AdminOrderIndexViewModel
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "_AdminLayout";
}

<section class="admin-orders-page">
    <header class="admin-page-header">
        <div>
            <span class="eyebrow dark"><i class="fa-solid fa-clipboard-list"></i> Bán hàng</span>
            <h1>Quản lý đơn hàng</h1>
            <p>Theo dõi, tra cứu và cập nhật tiến độ xử lý đơn hàng.</p>
        </div>
    </header>

    <div class="admin-stats-grid">
        <div class="admin-stat-card"><span>Tổng đơn hàng</span><strong>@Model.TotalOrders</strong></div>
        <div class="admin-stat-card"><span>Doanh thu hoàn thành</span><strong class="admin-stat-money">@UiFormat.Vnd(Model.CompletedRevenue)</strong></div>
        <div class="admin-stat-card"><span>Kết quả đang hiển thị</span><strong>@Model.Items.Count</strong></div>
    </div>

    <form asp-action="AdminIndex" method="get" class="admin-filter-card admin-order-filter">
        <div><label for="search">Mã đơn</label><input id="search" name="search" value="@Model.Search" class="form-control" placeholder="Ví dụ: SS-2026..." /></div>
        <div><label for="customerName">Tên khách hàng</label><input id="customerName" name="customerName" value="@Model.CustomerName" class="form-control" placeholder="Nhập tên khách hàng" /></div>
        <div><label for="phoneNumber">Số điện thoại</label><input id="phoneNumber" name="phoneNumber" value="@Model.PhoneNumber" class="form-control" inputmode="tel" placeholder="Nhập số điện thoại" /></div>
        <div>
            <label for="status">Trạng thái</label>
            <select id="status" name="status" class="form-select">
                <option value="">Tất cả trạng thái</option>
                @foreach (var status in Enum.GetValues<OrderStatus>())
                {
                    if (Model.Status == status) { <option value="@status" selected>@OrderDisplay.Status(status)</option> }
                    else { <option value="@status">@OrderDisplay.Status(status)</option> }
                }
            </select>
        </div>
        <div><label for="orderDate">Ngày đặt</label><input id="orderDate" name="orderDate" type="date" value="@Model.OrderDate?.ToString("yyyy-MM-dd")" class="form-control" /></div>
        <div class="admin-filter-actions">
            <button class="btn btn-primary-custom" type="submit"><i class="fa-solid fa-filter"></i> Lọc đơn hàng</button>
            <a class="btn btn-outline-custom" asp-action="AdminIndex"><i class="fa-solid fa-rotate-left"></i> Đặt lại</a>
        </div>
    </form>

    <div class="admin-table-card">
        @if (Model.Items.Count == 0)
        {
            <div class="admin-empty-state"><i class="fa-solid fa-receipt"></i><h2>Không tìm thấy đơn hàng.</h2><p>Hãy thay đổi điều kiện lọc hoặc kiểm tra lại từ khóa.</p></div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table admin-table align-middle">
                    <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Số điện thoại</th><th>Ngày đặt</th><th>Tổng tiền</th><th>Trạng thái</th><th>Thanh toán</th><th class="text-end">Thao tác</th></tr></thead>
                    <tbody>
                        @foreach (var order in Model.Items)
                        {
                            <tr>
                                <td><strong>@order.OrderCode</strong></td>
                                <td>@order.CustomerName</td>
                                <td>@order.PhoneNumber</td>
                                <td>@order.CreatedAt.ToString("dd/MM/yyyy")<small class="table-subtext">@order.CreatedAt.ToString("HH:mm")</small></td>
                                <td><strong class="admin-price">@UiFormat.Vnd(order.Total)</strong></td>
                                <td><span class="order-status @OrderDisplay.StatusClass(order.OrderStatus)">@OrderDisplay.Status(order.OrderStatus)</span></td>
                                <td><span class="payment-status @OrderDisplay.PaymentClass(order.PaymentStatus)">@OrderDisplay.Payment(order.PaymentStatus)</span></td>
                                <td><div class="admin-actions justify-content-end"><a class="action-btn view" asp-action="Details" asp-route-id="@order.Id" title="Xem chi tiết" aria-label="Xem chi tiết @order.OrderCode"><i class="fa-solid fa-eye"></i></a></div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
