@model List<OutfitSuggestion>
@{ ViewData["Title"] = "Quản lý gợi ý phối đồ"; }
<section class="outfit-admin-page"><div class="container"><nav class="breadcrumb-line" aria-label="Điều hướng"><a asp-controller="Admin" asp-action="Index">Bảng điều khiển</a><span>/</span><strong>Gợi ý phối đồ</strong></nav><div class="outfit-admin-heading"><div><span class="eyebrow dark"><i class="fa-solid fa-wand-magic-sparkles"></i> Phong cách thời trang</span><h1>Quản lý gợi ý phối đồ</h1><p>Liên kết các sản phẩm để khách hàng dễ hình dung một bộ trang phục hoàn chỉnh.</p></div><a class="btn btn-primary-custom" asp-action="Create"><i class="fa-solid fa-plus"></i> Thêm gợi ý mới</a></div>
@if (TempData["OutfitMessage"] != null) { <div class="alert cart-alert" role="alert"><i class="fa-solid fa-circle-check"></i><span>@TempData["OutfitMessage"]</span><button type="button" class="alert-close" aria-label="Đóng thông báo"><i class="fa-solid fa-xmark"></i></button></div> }
<div class="outfit-admin-table-wrap"><table class="outfit-admin-table"><thead><tr><th>Sản phẩm chính</th><th>Sản phẩm phối cùng</th><th>Tiêu đề gợi ý</th><th>Thứ tự</th><th>Trạng thái</th><th>Thao tác</th></tr></thead><tbody>
@if (Model.Count == 0) { <tr><td colspan="6" class="table-empty-message">Chưa có gợi ý phối đồ nào.</td></tr> }
@foreach (var item in Model) { <tr><td data-label="Sản phẩm chính"><strong>@item.Product.Name</strong></td><td data-label="Phối cùng">@item.SuggestedProduct.Name</td><td data-label="Tiêu đề">@(item.Title ?? "Gợi ý phối cùng")</td><td data-label="Thứ tự">@item.DisplayOrder</td><td data-label="Trạng thái"><span class="vietnamese-status-badge @(item.IsActive ? "is-visible" : "is-hidden")">@(item.IsActive ? "Đang hiển thị" : "Đã ẩn")</span></td><td data-label="Thao tác"><div class="outfit-row-actions"><a class="dashboard-icon-btn" asp-action="Edit" asp-route-id="@item.Id" title="Sửa"><i class="fa-solid fa-pen"></i></a><form asp-action="ToggleActive" asp-route-id="@item.Id" method="post">@Html.AntiForgeryToken()<button class="dashboard-icon-btn outfit-hide-btn" type="submit" title="@(item.IsActive ? "Ẩn" : "Hiển thị")"><i class="fa-solid @(item.IsActive ? "fa-eye-slash" : "fa-eye")"></i></button></form><a class="dashboard-icon-btn outfit-delete-btn" asp-action="Delete" asp-route-id="@item.Id" title="Xóa"><i class="fa-solid fa-trash-can"></i></a></div></td></tr> }
</tbody></table></div></div></section>
