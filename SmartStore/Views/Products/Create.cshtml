@model SmartStore.Models.Product
@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<section class="admin-section">
    <div class="container narrow-container">
        <div class="admin-page-heading">
            <a class="back-link" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Quay lại quản lý</a>
            <span class="eyebrow dark"><i class="fa-solid fa-plus"></i> Thêm mới</span>
            <h1>Thêm sản phẩm</h1>
        </div>

        <form asp-action="Create" method="post" class="admin-form-card">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-grid-two">
                <div class="form-group-custom">
                    <label asp-for="Name">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" placeholder="Ví dụ: Áo khoác local brand" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Category">Danh mục</label>
                    <input asp-for="Category" class="form-control" placeholder="Thời trang, Công nghệ..." />
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group-custom">
                <label asp-for="Description">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả ngắn gọn lợi ích, chất liệu, công dụng..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-grid-two">
                <div class="form-group-custom">
                    <label asp-for="Price">Giá bán</label>
                    <input id="Price"
                           name="Price"
                           value="@(Model.Price > 0 ? Model.Price.ToString("0") : "")"
                           class="form-control js-vnd-input"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           data-vnd-min="1000"
                           data-vnd-max="1000000000"
                           required
                           data-val="false" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="OldPrice">Giá cũ</label>
                    <input id="OldPrice"
                           name="OldPrice"
                           value="@(Model.OldPrice.HasValue ? Model.OldPrice.Value.ToString("0") : "")"
                           class="form-control js-vnd-input"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           data-vnd-min="0"
                           data-vnd-max="1000000000"
                           data-val="false" />
                    <span asp-validation-for="OldPrice" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid-two">
                <div class="form-group-custom">
                    <label asp-for="ImageUrl">Hình ảnh sản phẩm</label>
                    <input asp-for="ImageUrl" type="hidden" class="js-image-value" />
                    <div class="image-paste-box js-image-paste-box" tabindex="0">
                        <img class="image-paste-preview js-image-preview" src="@Model.ImageUrl" alt="Xem trước hình ảnh sản phẩm" />
                        <div class="image-paste-content">
                            <strong>Dán hình ảnh vào đây</strong>
                            <span>Copy ảnh rồi nhấn Ctrl + V, hoặc chọn ảnh từ máy.</span>
                            <button class="btn btn-outline-custom image-file-btn" type="button">Chọn ảnh</button>
                            <input class="js-image-file visually-hidden" type="file" accept="image/*" />
                        </div>
                    </div>
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    <small>Ảnh được lưu trực tiếp vào sản phẩm, không cần nhập link https.</small>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Badge">Nhãn nổi bật</label>
                    <input asp-for="Badge" class="form-control" placeholder="Hot, New, Sale..." />
                    <span asp-validation-for="Badge" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid-two">
                <div class="form-group-custom">
                    <label asp-for="Rating">Đánh giá</label>
                    <input asp-for="Rating" class="form-control" type="number" min="0" max="5" step="0.1" />
                    <span asp-validation-for="Rating" class="text-danger"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="StockStatus">Trạng thái kho</label>
                    <input asp-for="StockStatus" class="form-control" placeholder="Còn hàng / Hết hàng" />
                    <span asp-validation-for="StockStatus" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary-custom"><i class="fa-solid fa-floppy-disk me-1"></i> Lưu sản phẩm</button>
                <a class="btn btn-outline-custom" asp-action="Index">Hủy</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
