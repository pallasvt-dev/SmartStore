@model SmartStore.Models.Product
@{
    ViewData["Title"] = "Sửa sản phẩm";
}

<section class="admin-section">
    <div class="container narrow-container">
        <div class="admin-page-heading">
            <a class="back-link" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Quay lại quản lý</a>
            <span class="eyebrow dark"><i class="fa-solid fa-pen"></i> Cập nhật</span>
            <h1>Sửa sản phẩm</h1>
        </div>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="admin-form-card">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="edit-preview-card">
                <img class="js-edit-preview-image" src="@Model.ImageUrl" alt="@Model.Name" />
                <div>
                    <span>Đang chỉnh sửa</span>
                    <strong>@Model.Name</strong>
                    <p>ID sản phẩm: #@Model.Id</p>
                </div>
            </div>

            <div class="form-grid-two">
                <div class="form-group-custom">
                    <label asp-for="Name">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Category">Danh mục</label>
                    <input asp-for="Category" class="form-control" />
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group-custom">
                <label asp-for="Description">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-grid-two">
                <div class="form-group-custom">
                    <label asp-for="Price">Giá bán</label>
                    <input id="Price" name="Price" value="@Model.Price.ToString("0")" class="form-control js-vnd-input" type="text" inputmode="numeric" autocomplete="off" data-vnd-min="1000" data-vnd-max="1000000000" required data-val="false" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="OldPrice">Giá cũ</label>
                    <input id="OldPrice" name="OldPrice" value="@(Model.OldPrice.HasValue ? Model.OldPrice.Value.ToString("0") : "")" class="form-control js-vnd-input" type="text" inputmode="numeric" autocomplete="off" data-vnd-min="0" data-vnd-max="1000000000" data-val="false" />
                    <span asp-validation-for="OldPrice" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid-two">
                <div class="form-group-custom">
                    <label asp-for="ImageUrl">Hình ảnh sản phẩm</label>
                    <input asp-for="ImageUrl" type="hidden" class="js-image-value" />
                    <div class="image-paste-box js-image-paste-box" tabindex="0">
                        <img class="image-paste-preview js-image-preview" src="@Model.ImageUrl" alt="Xem trước hình ảnh sản phẩm" />
                        <div class="image-paste-content">
                            <strong>Dán hình ảnh vào đây</strong>
                            <button class="btn btn-outline-custom image-file-btn" type="button">Chọn ảnh</button>
                            <input class="js-image-file visually-hidden" type="file" accept="image/*" />
                        </div>
                    </div>
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    <small>Ảnh được lưu trực tiếp vào sản phẩm, không cần nhập link https.</small>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Badge">Nhãn nổi bật</label>
                    <input asp-for="Badge" class="form-control" />
                    <span asp-validation-for="Badge" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid-two">
                <div class="form-group-custom">
                    <label asp-for="Rating">Đánh giá</label>
                    <input asp-for="Rating" class="form-control" type="number" min="0" max="5" step="0.1" />
                    <span asp-validation-for="Rating" class="text-danger"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="StockStatus">Trạng thái kho</label>
                    <input asp-for="StockStatus" class="form-control" />
                    <span asp-validation-for="StockStatus" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary-custom"><i class="fa-solid fa-floppy-disk me-1"></i> Cập nhật</button>
                <a class="btn btn-outline-custom" asp-action="Index">Hủy</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
