@model SmartStore.Models.ProductFormViewModel
@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<section class="admin-section">
    <div class="container narrow-container">
        <div class="admin-page-heading">
            <a class="back-link" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Quay lại danh sách</a>
            <span class="eyebrow dark"><i class="fa-solid fa-pen"></i> Cập nhật</span>
            <h1>Cập nhật sản phẩm</h1>
        </div>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="admin-product-form">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <partial name="_ProductForm" model="Model" />
            <div class="form-actions">
                <button type="submit" class="btn btn-primary-custom"><i class="fa-solid fa-floppy-disk me-1"></i> Lưu thay đổi</button>
                <a class="btn btn-outline-custom" asp-action="Index">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
