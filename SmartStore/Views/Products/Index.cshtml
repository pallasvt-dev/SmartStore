@model IEnumerable<SmartStore.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<section class="admin-section">
    <div class="container">
        <div class="admin-hero">
            <div>
                <a class="back-link" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Về trang bán hàng</a>
                <span class="eyebrow dark"><i class="fa-solid fa-boxes-stacked"></i> Product</span>
            </div>
            <a class="btn btn-primary-custom" asp-action="Create"><i class="fa-solid fa-plus me-1"></i> Thêm sản phẩm</a>
        </div>

        @if (TempData["ProductMessage"] != null)
        {
            <div class="alert alert-success cart-alert" role="alert">
                <i class="fa-solid fa-circle-check"></i>
                <span>@TempData["ProductMessage"]</span>
            </div>
        }

        <div class="admin-stats-grid">
            <div class="admin-stat-card">
                <span>Tổng sản phẩm</span>
                <strong>@Model.Count()</strong>
            </div>
            <div class="admin-stat-card">
                <span>Còn hàng</span>
                <strong>@Model.Count(p => p.StockStatus.Contains("Còn"))</strong>
            </div>
            <div class="admin-stat-card">
                <span>Giá trung bình</span>
                <strong>@(Model.Any() ? Model.Average(p => p.Price).ToString("N0") : "0") đ</strong>
            </div>
        </div>

        <div class="admin-table-card">
            <div class="admin-table-header">
                <div>
                    <h2>Danh sách sản phẩm</h2>
                </div>
                <a class="btn btn-outline-custom" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-eye me-1"></i> Xem giao diện khách</a>
            </div>

            <div class="table-responsive">
                <table class="table product-admin-table align-middle">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá bán</th>
                            <th>Đánh giá</th>
                            <th>Kho</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td>
                                    <div class="admin-product-cell">
                                        <img src="@product.ImageUrl" alt="@product.Name" />
                                        <div>
                                            <strong>@product.Name</strong>
                                            <span>@product.Badge</span>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="admin-chip">@product.Category</span></td>
                                <td>
                                    <strong class="admin-price">@product.Price.ToString("N0") đ</strong>
                                    @if (product.OldPrice.HasValue)
                                    {
                                        <del>@product.OldPrice.Value.ToString("N0") đ</del>
                                    }
                                </td>
                                <td><span class="rating"><i class="fa-solid fa-star"></i> @product.Rating</span></td>
                                <td><span class="stock-pill">@product.StockStatus</span></td>
                                <td>
                                    <div class="admin-actions justify-content-end">
                                        <a class="action-btn view" asp-action="Details" asp-route-id="@product.Id" title="Xem chi tiết"><i class="fa-solid fa-eye"></i></a>
                                        <a class="action-btn edit" asp-action="Edit" asp-route-id="@product.Id" title="Sửa"><i class="fa-solid fa-pen"></i></a>
                                        <a class="action-btn delete" asp-action="Delete" asp-route-id="@product.Id" title="Xóa"><i class="fa-solid fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
