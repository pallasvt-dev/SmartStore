@model IEnumerable<SmartStore.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<section class="admin-section">
    <div class="container">
        <div class="admin-hero">
            <div>
                <a class="back-link" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-arrow-left"></i> Về trang bán hàng</a>
                <span class="eyebrow dark"><i class="fa-solid fa-shirt"></i> Danh mục thời trang</span>
                <h1>Quản lý sản phẩm</h1>
            </div>
            <a class="btn btn-primary-custom" asp-action="Create"><i class="fa-solid fa-plus me-1"></i> Thêm sản phẩm mới</a>
        </div>

        @if (TempData["ProductMessage"] != null)
        {
            <div class="alert alert-success cart-alert" role="alert">
                <i class="fa-solid fa-circle-check"></i>
                <span>@TempData["ProductMessage"]</span>
            </div>
        }

        <div class="admin-stats-grid">
            <div class="admin-stat-card">
                <span>Tổng sản phẩm</span>
                <strong>@Model.Count()</strong>
            </div>
            <div class="admin-stat-card">
                <span>Tổng biến thể</span>
                <strong>@Model.Sum(p => p.ProductVariants.Count(v => v.IsActive))</strong>
            </div>
            <div class="admin-stat-card">
                <span>Tổng tồn kho</span>
                <strong>@Model.Sum(p => p.ProductVariants.Where(v => v.IsActive).Sum(v => v.StockQuantity))</strong>
            </div>
        </div>

        <div class="admin-table-card">
            <div class="admin-table-header">
                <div>
                    <h2>Danh sách sản phẩm</h2>
                    <p>Tìm theo tên sản phẩm, SKU, danh mục hoặc thương hiệu bằng công cụ tìm kiếm của trình duyệt.</p>
                </div>
                <a class="btn btn-outline-custom" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-eye me-1"></i> Xem giao diện khách</a>
            </div>

            <div class="table-responsive">
                <table class="table product-admin-table align-middle">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Thương hiệu</th>
                            <th>Giá bán</th>
                            <th>Tồn kho</th>
                            <th>Biến thể</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            var mainImage = product.ProductImages.OrderByDescending(i => i.IsMain).ThenBy(i => i.DisplayOrder).FirstOrDefault()?.ImageUrl;
                            var totalStock = product.ProductVariants.Where(v => v.IsActive).Sum(v => v.StockQuantity);
                            var variantCount = product.ProductVariants.Count(v => v.IsActive);
                            <tr>
                                <td>
                                    <div class="admin-product-cell">
                                        <img src="@mainImage" alt="@product.Name" />
                                        <div>
                                            <strong>@product.Name</strong>
                                            <span>@(product.Badge ?? "Đang bán")</span>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="admin-chip">@product.Category.Name</span></td>
                                <td>@(product.Brand?.Name ?? "Chưa có")</td>
                                <td>
                                    <strong class="admin-price">@UiFormat.Vnd(product.Price)</strong>
                                    @if (product.OldPrice.HasValue)
                                    {
                                        <del>@UiFormat.Vnd(product.OldPrice.Value)</del>
                                    }
                                </td>
                                <td><strong>@totalStock</strong></td>
                                <td>@variantCount</td>
                                <td><span class="stock-pill">@UiFormat.StockStatus(totalStock)</span></td>
                                <td>
                                    <div class="admin-actions justify-content-end">
                                        <a class="action-btn view" asp-action="Details" asp-route-id="@product.Id" title="Chi tiết"><i class="fa-solid fa-eye"></i></a>
                                        <a class="action-btn edit" asp-action="Edit" asp-route-id="@product.Id" title="Cập nhật"><i class="fa-solid fa-pen"></i></a>
                                        <a class="action-btn delete" asp-action="Delete" asp-route-id="@product.Id" title="Ngừng bán"><i class="fa-solid fa-ban"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
